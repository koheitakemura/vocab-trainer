{
  "name": "vocab-trainer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "語彙特化学習アプリ（サーバーレス・Vite 静的 SPA）",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "typecheck": "tsc -b --noEmit",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-fsrs": "^5.4.1",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.110.0"
  }
}
