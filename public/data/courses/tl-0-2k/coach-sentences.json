[{"text": "Magandang umaga!", "translation": "おはようございます！", "words": ["tl-0-2k-0104", "tl-0-2k-0264"], "tag": "morning"}, {"text": "Bangon na, umaga na.", "translation": "起きて、もう朝だよ。", "words": ["tl-0-2k-0842", "tl-0-2k-0264"], "tag": "morning"}, {"text": "Sikat na ang araw.", "translation": "もう日が昇っているよ。", "words": ["tl-0-2k-0704", "tl-0-2k-0080"], "tag": "morning"}, {"text": "Kape muna bago ang klase.", "translation": "授業の前にまずコーヒーを。", "words": ["tl-0-2k-0915", "tl-0-2k-0193", "tl-0-2k-0059", "tl-0-2k-0552"], "tag": "morning"}, {"text": "Uminom ka ng tubig, tapos kumain ka.", "translation": "水を飲んで、それから食べてね。", "words": ["tl-0-2k-0337", "tl-0-2k-0246", "tl-0-2k-0135", "tl-0-2k-0157"], "tag": "morning"}, {"text": "Bagong araw, bagong simula.", "translation": "新しい日、新しいスタート。", "words": ["tl-0-2k-0059", "tl-0-2k-0080", "tl-0-2k-0208"], "tag": "morning"}, {"text": "Handa ka na ba sa umaga?", "translation": "朝の準備はできた？", "words": ["tl-0-2k-0269", "tl-0-2k-0264"], "tag": "morning"}, {"text": "Almusal muna, tapos aral.", "translation": "まず朝ごはん、それから勉強。", "words": ["tl-0-2k-1243", "tl-0-2k-0193", "tl-0-2k-0135", "tl-0-2k-0146"], "tag": "morning"}, {"text": "Malinaw ang langit ngayong umaga.", "translation": "今朝は空が澄んでいるね。", "words": ["tl-0-2k-0551", "tl-0-2k-0433", "tl-0-2k-0040", "tl-0-2k-0264"], "tag": "morning"}, {"text": "Maganda ang panahon, simulan na natin.", "translation": "いい天気だね、始めよう。", "words": ["tl-0-2k-0104", "tl-0-2k-0138", "tl-0-2k-0208", "tl-0-2k-0076"], "tag": "morning"}, {"text": "Itlog at tinapay para sa almusal.", "translation": "朝ごはんは卵とパン。", "words": ["tl-0-2k-1051", "tl-0-2k-1593", "tl-0-2k-0117", "tl-0-2k-1243"], "tag": "morning"}, {"text": "May liwanag na sa bintana, umaga na.", "translation": "窓にもう光があるよ、朝だね。", "words": ["tl-0-2k-0317", "tl-0-2k-0501", "tl-0-2k-0264"], "tag": "morning"}, {"text": "Malamig pa ang umaga ngayon.", "translation": "今朝はまだ涼しいね。", "words": ["tl-0-2k-0373", "tl-0-2k-0264", "tl-0-2k-0040"], "tag": "morning"}, {"text": "Salita muna bago magtrabaho.", "translation": "仕事の前に、まず言葉から。", "words": ["tl-0-2k-0085", "tl-0-2k-0193", "tl-0-2k-0059", "tl-0-2k-0226"], "tag": "morning"}, {"text": "Kumusta ang tulog mo kagabi?", "translation": "昨夜はよく眠れた？", "words": ["tl-0-2k-0520", "tl-0-2k-0228", "tl-0-2k-0664"], "tag": "morning"}, {"text": "Simulan natin nang maaga.", "translation": "早めに始めよう。", "words": ["tl-0-2k-0208", "tl-0-2k-0076", "tl-0-2k-0027", "tl-0-2k-0500"], "tag": "morning"}, {"text": "Magandang hapon!", "translation": "こんにちは！", "words": ["tl-0-2k-0104", "tl-0-2k-0330"], "tag": "afternoon"}, {"text": "Oras na ng tanghalian.", "translation": "お昼ごはんの時間だよ。", "words": ["tl-0-2k-0230", "tl-0-2k-1155"], "tag": "afternoon"}, {"text": "Pagod ka na ba? Tubig muna.", "translation": "もう疲れた？まず水を飲んで。", "words": ["tl-0-2k-0605", "tl-0-2k-0246", "tl-0-2k-0193"], "tag": "afternoon"}, {"text": "Tuloy pa rin tayo sa hapon.", "translation": "午後も続けていこう。", "words": ["tl-0-2k-0180", "tl-0-2k-0026", "tl-0-2k-0058", "tl-0-2k-0330"], "tag": "afternoon"}, {"text": "Init ng araw ngayong hapon.", "translation": "今日の午後は暑いね。", "words": ["tl-0-2k-0282", "tl-0-2k-0080", "tl-0-2k-0040", "tl-0-2k-0330"], "tag": "afternoon"}, {"text": "Kaunting pahinga, tapos balik tayo.", "translation": "少し休んで、それから戻ろう。", "words": ["tl-0-2k-0278", "tl-0-2k-0721", "tl-0-2k-0135", "tl-0-2k-0142", "tl-0-2k-0058"], "tag": "afternoon"}, {"text": "Kape sa hapon, bakit hindi?", "translation": "午後のコーヒー、いいじゃない？", "words": ["tl-0-2k-0915", "tl-0-2k-0330", "tl-0-2k-0045", "tl-0-2k-0009"], "tag": "afternoon"}, {"text": "Kalahati na, tuloy lang tayo.", "translation": "もう半分、このまま続けよう。", "words": ["tl-0-2k-0769", "tl-0-2k-0180", "tl-0-2k-0033", "tl-0-2k-0058"], "tag": "afternoon"}, {"text": "Antok ka na? Lumabas ka muna.", "translation": "眠い？少し外に出てみて。", "words": ["tl-0-2k-1182", "tl-0-2k-0103", "tl-0-2k-0193"], "tag": "afternoon"}, {"text": "Panahon na para sa bagong salita.", "translation": "新しい言葉の時間だよ。", "words": ["tl-0-2k-0138", "tl-0-2k-0117", "tl-0-2k-0059", "tl-0-2k-0085"], "tag": "afternoon"}, {"text": "Lumabas ka, tingnan mo ang langit.", "translation": "外に出て、空を見てみて。", "words": ["tl-0-2k-0103", "tl-0-2k-0089", "tl-0-2k-0433"], "tag": "afternoon"}, {"text": "Isang tanghalian, isang aral.", "translation": "昼ごはんひとつ、学びひとつ。", "words": ["tl-0-2k-0014", "tl-0-2k-1155", "tl-0-2k-0146"], "tag": "afternoon"}, {"text": "Huwag kang matakot, kaya mo ito.", "translation": "怖がらないで、あなたならできる。", "words": ["tl-0-2k-0092", "tl-0-2k-0237", "tl-0-2k-0299", "tl-0-2k-0024"], "tag": "afternoon"}, {"text": "Tandaan mo bago tayo magpahinga.", "translation": "休む前に、覚えておこうね。", "words": ["tl-0-2k-0341", "tl-0-2k-0059", "tl-0-2k-0058", "tl-0-2k-0721"], "tag": "afternoon"}, {"text": "Magandang gabi.", "translation": "こんばんは。", "words": ["tl-0-2k-0104", "tl-0-2k-0127"], "tag": "evening"}, {"text": "Hapunan na, tapos pahinga.", "translation": "夕ごはんだよ、それから休もう。", "words": ["tl-0-2k-0986", "tl-0-2k-0135", "tl-0-2k-0721"], "tag": "evening"}, {"text": "Ano ang hapunan ngayong gabi?", "translation": "今夜の夕ごはんは何？", "words": ["tl-0-2k-0032", "tl-0-2k-0986", "tl-0-2k-0040", "tl-0-2k-0127"], "tag": "evening"}, {"text": "Malamig na ang hangin ngayong gabi.", "translation": "今夜は風が涼しくなってきたね。", "words": ["tl-0-2k-0373", "tl-0-2k-0395", "tl-0-2k-0040", "tl-0-2k-0127"], "tag": "evening"}, {"text": "Trabaho tapos na, ingat sa uwi.", "translation": "仕事は終わり、気をつけて帰ってね。", "words": ["tl-0-2k-0226", "tl-0-2k-0135", "tl-0-2k-0411", "tl-0-2k-0183"], "tag": "evening"}, {"text": "Maghugas ka, tapos magpahinga.", "translation": "体を洗って、それから休んでね。", "words": ["tl-0-2k-1337", "tl-0-2k-0135", "tl-0-2k-0721"], "tag": "evening"}, {"text": "Kanta muna tayo bago matulog.", "translation": "寝る前に、少し歌おう。", "words": ["tl-0-2k-1040", "tl-0-2k-0193", "tl-0-2k-0058", "tl-0-2k-0059", "tl-0-2k-0228"], "tag": "evening"}, {"text": "Maganda ang langit ngayong hapon.", "translation": "今夕の空はきれいだね。", "words": ["tl-0-2k-0104", "tl-0-2k-0433", "tl-0-2k-0040", "tl-0-2k-0330"], "tag": "evening"}, {"text": "Kape o gatas, alin ang gusto mo?", "translation": "コーヒーと牛乳、どっちがいい？", "words": ["tl-0-2k-0915", "tl-0-2k-0970", "tl-0-2k-0564", "tl-0-2k-0078"], "tag": "evening"}, {"text": "Buwan na ang sikat, hapunan na.", "translation": "月が出てきた、夕ごはんの時間だよ。", "words": ["tl-0-2k-0288", "tl-0-2k-0704", "tl-0-2k-0986"], "tag": "evening"}, {"text": "Salita ngayong gabi, tulog mamaya.", "translation": "今夜は言葉を、後で眠ろう。", "words": ["tl-0-2k-0085", "tl-0-2k-0040", "tl-0-2k-0127", "tl-0-2k-0228", "tl-0-2k-0568"], "tag": "evening"}, {"text": "Uwi na tayo, gabi na.", "translation": "帰ろう、もう夜だよ。", "words": ["tl-0-2k-0183", "tl-0-2k-0058", "tl-0-2k-0127"], "tag": "evening"}, {"text": "Isang aral bago ang hapunan.", "translation": "夕ごはんの前にひとつ学ぼう。", "words": ["tl-0-2k-0014", "tl-0-2k-0146", "tl-0-2k-0059", "tl-0-2k-0986"], "tag": "evening"}, {"text": "Buhok mo, ayusin mo bago matulog.", "translation": "髪、寝る前に整えてね。", "words": ["tl-0-2k-0506", "tl-0-2k-0254", "tl-0-2k-0059", "tl-0-2k-0228"], "tag": "evening"}, {"text": "Magandang gabi, matulog ka na.", "translation": "おやすみ、もう寝てね。", "words": ["tl-0-2k-0104", "tl-0-2k-0127", "tl-0-2k-0228"], "tag": "night"}, {"text": "Maraming bituin ngayong gabi.", "translation": "今夜は星がたくさんだね。", "words": ["tl-0-2k-0064", "tl-0-2k-1231", "tl-0-2k-0040", "tl-0-2k-0127"], "tag": "night"}, {"text": "Isara mo ang bintana, malamig na.", "translation": "窓を閉めて、寒くなってきたよ。", "words": ["tl-0-2k-0777", "tl-0-2k-0501", "tl-0-2k-0373"], "tag": "night"}, {"text": "Tahimik na ang gabi.", "translation": "夜は静かになったね。", "words": ["tl-0-2k-0333", "tl-0-2k-0127"], "tag": "night"}, {"text": "Dilim na sa labas, oras na ng tulog.", "translation": "外はもう暗い、眠る時間だよ。", "words": ["tl-0-2k-0376", "tl-0-2k-0103", "tl-0-2k-0230", "tl-0-2k-0228"], "tag": "night"}, {"text": "Isip mo ang bukas, tapos matulog ka na.", "translation": "明日のことを考えて、それから眠ってね。", "words": ["tl-0-2k-0050", "tl-0-2k-0242", "tl-0-2k-0135", "tl-0-2k-0228"], "tag": "night"}, {"text": "Gatas bago matulog, mabuti iyan.", "translation": "寝る前に牛乳、いいことだよ。", "words": ["tl-0-2k-0970", "tl-0-2k-0059", "tl-0-2k-0228", "tl-0-2k-0096", "tl-0-2k-0052"], "tag": "night"}, {"text": "Payapa ang gabi ngayon.", "translation": "今夜は穏やかだね。", "words": ["tl-0-2k-0841", "tl-0-2k-0127", "tl-0-2k-0040"], "tag": "night"}, {"text": "Higa ka na, tapos na ang araw.", "translation": "横になって、一日は終わったよ。", "words": ["tl-0-2k-0849", "tl-0-2k-0135", "tl-0-2k-0080"], "tag": "night"}, {"text": "Buwan at bituin, ang ganda nila.", "translation": "月と星、なんて美しいんだろう。", "words": ["tl-0-2k-0288", "tl-0-2k-1231", "tl-0-2k-0104", "tl-0-2k-0055"], "tag": "night"}, {"text": "Tanda mo ang salita, tapos tulog na.", "translation": "言葉を覚えて、それから眠ろうね。", "words": ["tl-0-2k-0341", "tl-0-2k-0085", "tl-0-2k-0135", "tl-0-2k-0228"], "tag": "night"}, {"text": "Ilan ang bituin sa langit ngayon?", "translation": "今夜は空に星がいくつ見える？", "words": ["tl-0-2k-0106", "tl-0-2k-1231", "tl-0-2k-0433", "tl-0-2k-0040"], "tag": "night"}, {"text": "Huwag kang matakot sa dilim.", "translation": "暗闇を怖がらないでね。", "words": ["tl-0-2k-0092", "tl-0-2k-0237", "tl-0-2k-0376"], "tag": "night"}, {"text": "Isang bituin, isang pangarap.", "translation": "星ひとつ、夢ひとつ。", "words": ["tl-0-2k-0014", "tl-0-2k-1231", "tl-0-2k-0536"], "tag": "night"}, {"text": "Galing mo talaga!", "translation": "本当にすごいね！", "words": ["tl-0-2k-0339", "tl-0-2k-0088"], "tag": "praise"}, {"text": "Mahusay, tuloy lang!", "translation": "上手だよ、その調子！", "words": ["tl-0-2k-0525", "tl-0-2k-0180", "tl-0-2k-0033"], "tag": "praise"}, {"text": "Maraming salamat, husay mo.", "translation": "本当にありがとう、上手だね。", "words": ["tl-0-2k-0064", "tl-0-2k-0359", "tl-0-2k-0525"], "tag": "praise"}, {"text": "Tama lahat ng sagot mo!", "translation": "答え、全部合ってるよ！", "words": ["tl-0-2k-0224", "tl-0-2k-0054", "tl-0-2k-0105"], "tag": "praise"}, {"text": "Mabilis kang natuto ngayon.", "translation": "今日は覚えるのが早いね。", "words": ["tl-0-2k-0328", "tl-0-2k-0466", "tl-0-2k-0040"], "tag": "praise"}, {"text": "Dumarami ang salita mong alam.", "translation": "知ってる言葉がどんどん増えているね。", "words": ["tl-0-2k-0064", "tl-0-2k-0085", "tl-0-2k-0039"], "tag": "praise"}, {"text": "Ang galing mo, walang mali.", "translation": "すごいね、間違いなしだよ。", "words": ["tl-0-2k-0339", "tl-0-2k-0022", "tl-0-2k-0340"], "tag": "praise"}, {"text": "Puno ng sigla ang aral mo ngayon.", "translation": "今日の勉強は元気いっぱいだね。", "words": ["tl-0-2k-0441", "tl-0-2k-0560", "tl-0-2k-0146", "tl-0-2k-0040"], "tag": "praise"}, {"text": "Husay mo, tandaan mo lahat.", "translation": "上手だね、全部覚えているよ。", "words": ["tl-0-2k-0525", "tl-0-2k-0341", "tl-0-2k-0054"], "tag": "praise"}, {"text": "Tuwang-tuwa ako sa ginawa mo.", "translation": "あなたのしたことがとても嬉しいよ。", "words": ["tl-0-2k-0358", "tl-0-2k-0016", "tl-0-2k-0038"], "tag": "praise"}, {"text": "Bawat salita mo, tama.", "translation": "どの言葉も、あなたは正しいよ。", "words": ["tl-0-2k-0251", "tl-0-2k-0085", "tl-0-2k-0224"], "tag": "praise"}, {"text": "Ang lakas ng loob mo ngayon.", "translation": "今日は本当に度胸があるね。", "words": ["tl-0-2k-0148", "tl-0-2k-0086", "tl-0-2k-0040"], "tag": "praise"}, {"text": "Alam mo na ang lahat ng ito.", "translation": "もうこれ全部わかっているね。", "words": ["tl-0-2k-0039", "tl-0-2k-0054", "tl-0-2k-0024"], "tag": "praise"}, {"text": "Bumuti ka talaga sa aral.", "translation": "勉強、本当に上達したね。", "words": ["tl-0-2k-0096", "tl-0-2k-0088", "tl-0-2k-0146"], "tag": "praise"}, {"text": "Kaya mo pala, ang galing!", "translation": "できるんだね、すごいよ！", "words": ["tl-0-2k-0299", "tl-0-2k-0108", "tl-0-2k-0339"], "tag": "praise"}, {"text": "Isa kang mahusay na estudyante.", "translation": "あなたは優秀な生徒だね。", "words": ["tl-0-2k-0014", "tl-0-2k-0525", "tl-0-2k-0676"], "tag": "praise"}, {"text": "Tuwa ako, salamat sa pagsisikap mo.", "translation": "嬉しいよ、頑張ってくれてありがとう。", "words": ["tl-0-2k-0358", "tl-0-2k-0016", "tl-0-2k-0359", "tl-0-2k-1841"], "tag": "praise"}, {"text": "Sarap pagmasdan ang husay mo.", "translation": "あなたの上手さを見るのは気持ちいいね。", "words": ["tl-0-2k-0449", "tl-0-2k-0424", "tl-0-2k-0525"], "tag": "praise"}, {"text": "Ang galing mo ngayon!", "translation": "今日は本当にすごいね！", "words": ["tl-0-2k-0339", "tl-0-2k-0040"], "tag": "bigday"}, {"text": "Maraming-marami ang natutunan mo.", "translation": "たくさんのことを学んだね。", "words": ["tl-0-2k-0064", "tl-0-2k-0466"], "tag": "bigday"}, {"text": "Isang bundok ng salita, tapos mo!", "translation": "山ほどの言葉、やり遂げたね！", "words": ["tl-0-2k-0014", "tl-0-2k-0482", "tl-0-2k-0085", "tl-0-2k-0135"], "tag": "bigday"}, {"text": "Ang laki ng nagawa mo ngayon.", "translation": "今日はとても大きなことを成し遂げたね。", "words": ["tl-0-2k-0069", "tl-0-2k-0038", "tl-0-2k-0040"], "tag": "bigday"}, {"text": "Wala akong salita, ang galing mo!", "translation": "言葉が出ないよ、すごすぎる！", "words": ["tl-0-2k-0022", "tl-0-2k-0016", "tl-0-2k-0085", "tl-0-2k-0339"], "tag": "bigday"}, {"text": "Pagod ka na siguro, magpahinga ka.", "translation": "もう疲れたでしょう、休んでね。", "words": ["tl-0-2k-0605", "tl-0-2k-0202", "tl-0-2k-0721"], "tag": "bigday"}, {"text": "Isang magandang araw ito.", "translation": "今日は素晴らしい一日だね。", "words": ["tl-0-2k-0014", "tl-0-2k-0104", "tl-0-2k-0080", "tl-0-2k-0024"], "tag": "bigday"}, {"text": "Tuwa ang guro mo sa ginawa mo.", "translation": "先生もあなたのしたことに喜んでいるよ。", "words": ["tl-0-2k-0358", "tl-0-2k-0592", "tl-0-2k-0038"], "tag": "bigday"}, {"text": "Bihira ang tulad mo, husay talaga.", "translation": "あなたみたいな人はめったにいない、本当にすごい。", "words": ["tl-0-2k-1166", "tl-0-2k-0185", "tl-0-2k-0525", "tl-0-2k-0088"], "tag": "bigday"}, {"text": "Kanin at kape ngayong gabi, salamat sa husay mo.", "translation": "今夜はご飯とコーヒー、あなたの頑張りに感謝だよ。", "words": ["tl-0-2k-1070", "tl-0-2k-0915", "tl-0-2k-0040", "tl-0-2k-0127", "tl-0-2k-0359", "tl-0-2k-0525"], "tag": "bigday"}, {"text": "Huwag kang matakot, tapos na ang mahirap na bahagi.", "translation": "怖がらないで、大変な部分はもう終わったよ。", "words": ["tl-0-2k-0092", "tl-0-2k-0237", "tl-0-2k-0135", "tl-0-2k-0130", "tl-0-2k-0334"], "tag": "bigday"}, {"text": "Malaking hakbang ito para sa iyo.", "translation": "これはあなたにとって大きな一歩だよ。", "words": ["tl-0-2k-0069", "tl-0-2k-0652", "tl-0-2k-0024", "tl-0-2k-0117", "tl-0-2k-0049"], "tag": "bigday"}, {"text": "Malapit ka na sa tapos.", "translation": "終わりまであと少しだよ。", "words": ["tl-0-2k-0123", "tl-0-2k-0135"], "tag": "milestone"}, {"text": "Higit sa kalahati na tayo.", "translation": "もう半分以上進んだよ。", "words": ["tl-0-2k-0214", "tl-0-2k-0769", "tl-0-2k-0058"], "tag": "milestone"}, {"text": "Abot-kamay mo na ang pangarap.", "translation": "夢はもう手の届くところにあるよ。", "words": ["tl-0-2k-0190", "tl-0-2k-0164", "tl-0-2k-0536"], "tag": "milestone"}, {"text": "Isang bundok, akyat na akyat.", "translation": "山ひとつ、着実に登っているね。", "words": ["tl-0-2k-0014", "tl-0-2k-0482", "tl-0-2k-0507"], "tag": "milestone"}, {"text": "Malapit ka na sa bundok na iyon.", "translation": "あの山まであと少しだよ。", "words": ["tl-0-2k-0123", "tl-0-2k-0482", "tl-0-2k-0029"], "tag": "milestone"}, {"text": "Bawat hakbang mo, mas malapit sa tapos.", "translation": "一歩ずつ、終わりに近づいているね。", "words": ["tl-0-2k-0251", "tl-0-2k-0652", "tl-0-2k-0259", "tl-0-2k-0123", "tl-0-2k-0135"], "tag": "milestone"}, {"text": "May liwanag na sa dulo.", "translation": "先にはもう光があるよ。", "words": ["tl-0-2k-0317", "tl-0-2k-0635"], "tag": "milestone"}, {"text": "Malaki nang bahagi ang tapos na.", "translation": "もう大部分が終わったね。", "words": ["tl-0-2k-0069", "tl-0-2k-0027", "tl-0-2k-0334", "tl-0-2k-0135"], "tag": "milestone"}, {"text": "Pangarap mo, malapit na malapit na.", "translation": "あなたの夢、もうすぐそこだよ。", "words": ["tl-0-2k-0536", "tl-0-2k-0123"], "tag": "milestone"}, {"text": "Isa na lang, tapos na tayo.", "translation": "あとひとつで終わりだよ。", "words": ["tl-0-2k-0014", "tl-0-2k-0033", "tl-0-2k-0135", "tl-0-2k-0058"], "tag": "milestone"}, {"text": "Bagong ikaw, malapit na.", "translation": "新しいあなたに、もうすぐ会えるよ。", "words": ["tl-0-2k-0059", "tl-0-2k-0118", "tl-0-2k-0123"], "tag": "milestone"}, {"text": "Tandaan mo, malapit ka na sa tuktok.", "translation": "覚えておいて、頂上はもうすぐだよ。", "words": ["tl-0-2k-0341", "tl-0-2k-0123", "tl-0-2k-1752"], "tag": "milestone"}, {"text": "Dito ka na dumating, magaling.", "translation": "ここまで来たね、すごいよ。", "words": ["tl-0-2k-0046", "tl-0-2k-0072", "tl-0-2k-0339"], "tag": "milestone"}, {"text": "Malapit ka na sa iyong pangarap.", "translation": "あなたの夢まで、もうすぐだよ。", "words": ["tl-0-2k-0123", "tl-0-2k-0049", "tl-0-2k-0536"], "tag": "milestone"}, {"text": "Kumusta, matagal ka nang wala dito.", "translation": "おかえり、久しぶりだね。", "words": ["tl-0-2k-0520", "tl-0-2k-0160", "tl-0-2k-0027", "tl-0-2k-0022", "tl-0-2k-0046"], "tag": "comeback"}, {"text": "Balik ka na, salamat.", "translation": "戻ってきてくれて、ありがとう。", "words": ["tl-0-2k-0142", "tl-0-2k-0359"], "tag": "comeback"}, {"text": "Hinihintay ka namin dito.", "translation": "ここでずっと待っていたよ。", "words": ["tl-0-2k-0212", "tl-0-2k-0097", "tl-0-2k-0046"], "tag": "comeback"}, {"text": "Ayos lang, dahan-dahan tayo ngayon.", "translation": "大丈夫、今日はゆっくりいこう。", "words": ["tl-0-2k-0254", "tl-0-2k-0033", "tl-0-2k-0931", "tl-0-2k-0058", "tl-0-2k-0040"], "tag": "comeback"}, {"text": "Muli tayong magsimula ngayon.", "translation": "今日からまた始めよう。", "words": ["tl-0-2k-0178", "tl-0-2k-0058", "tl-0-2k-0208", "tl-0-2k-0040"], "tag": "comeback"}, {"text": "Kahit kaunti lang, sige tayo.", "translation": "少しだけでも、始めよう。", "words": ["tl-0-2k-0098", "tl-0-2k-0278", "tl-0-2k-0033", "tl-0-2k-0268", "tl-0-2k-0058"], "tag": "comeback"}, {"text": "Ang saya, bumalik ka na naman.", "translation": "嬉しいな、また戻ってきてくれたね。", "words": ["tl-0-2k-0367", "tl-0-2k-0142", "tl-0-2k-0028"], "tag": "comeback"}, {"text": "Wala kang dapat ikahiya, balik lang tayo.", "translation": "恥じることは何もないよ、ただ戻ろう。", "words": ["tl-0-2k-0022", "tl-0-2k-0100", "tl-0-2k-0400", "tl-0-2k-0142", "tl-0-2k-0033", "tl-0-2k-0058"], "tag": "comeback"}, {"text": "Pinto namin, bukas palagi para sa iyo.", "translation": "私たちのドアは、いつもあなたに開かれているよ。", "words": ["tl-0-2k-0300", "tl-0-2k-0097", "tl-0-2k-0242", "tl-0-2k-0755", "tl-0-2k-0117", "tl-0-2k-0049"], "tag": "comeback"}, {"text": "Kanina ka pa naming hinihintay.", "translation": "さっきからずっと待っていたよ。", "words": ["tl-0-2k-0280", "tl-0-2k-0097", "tl-0-2k-0212"], "tag": "comeback"}, {"text": "Isang salita muna, tapos tuloy tayo.", "translation": "まずひとつの言葉から、それから続けよう。", "words": ["tl-0-2k-0014", "tl-0-2k-0085", "tl-0-2k-0193", "tl-0-2k-0135", "tl-0-2k-0180", "tl-0-2k-0058"], "tag": "comeback"}, {"text": "Kaibigan ka namin, kahit gaano katagal.", "translation": "どれだけ経っても、あなたは私たちの友達だよ。", "words": ["tl-0-2k-0154", "tl-0-2k-0097", "tl-0-2k-0098", "tl-0-2k-0483", "tl-0-2k-0160"], "tag": "comeback"}, {"text": "Tandaan mo, kaya mo ulit ito.", "translation": "覚えておいて、また出来るよ。", "words": ["tl-0-2k-0341", "tl-0-2k-0299", "tl-0-2k-0364", "tl-0-2k-0024"], "tag": "comeback"}, {"text": "Hindi mahalaga ang tagal, mahalaga ang balik.", "translation": "どれだけ経ったかより、戻ってきたことが大切だよ。", "words": ["tl-0-2k-0009", "tl-0-2k-0204", "tl-0-2k-0160", "tl-0-2k-0142"], "tag": "comeback"}, {"text": "Kaya mo ito.", "translation": "あなたならできるよ。", "words": ["tl-0-2k-0299", "tl-0-2k-0024"], "tag": "encourage"}, {"text": "Isang salita sa isang araw.", "translation": "一日にひとつの言葉を。", "words": ["tl-0-2k-0014", "tl-0-2k-0085", "tl-0-2k-0080"], "tag": "encourage"}, {"text": "Huwag kang matakot, dahan-dahan lang.", "translation": "怖がらないで、ゆっくりでいいよ。", "words": ["tl-0-2k-0092", "tl-0-2k-0237", "tl-0-2k-0931", "tl-0-2k-0033"], "tag": "encourage"}, {"text": "Palagi kang may tiwala sa akin.", "translation": "いつも私を信じていてね。", "words": ["tl-0-2k-0755", "tl-0-2k-0774", "tl-0-2k-0031"], "tag": "encourage"}, {"text": "Bawat aral, isang hakbang palapit sa pangarap.", "translation": "学びひとつごとに、夢へ一歩近づくよ。", "words": ["tl-0-2k-0251", "tl-0-2k-0146", "tl-0-2k-0014", "tl-0-2k-0652", "tl-0-2k-1512", "tl-0-2k-0536"], "tag": "encourage"}, {"text": "Kahapon ay tapos na, ngayon ay bago.", "translation": "昨日は終わった、今日は新しい日だよ。", "words": ["tl-0-2k-0570", "tl-0-2k-0135", "tl-0-2k-0040", "tl-0-2k-0059"], "tag": "encourage"}, {"text": "May pag-asa palagi, kahit mahirap.", "translation": "難しくても、いつも希望はあるよ。", "words": ["tl-0-2k-0587", "tl-0-2k-0755", "tl-0-2k-0098", "tl-0-2k-0130"], "tag": "encourage"}, {"text": "Tapang lang, kaya mo ito.", "translation": "勇気を出して、あなたならできる。", "words": ["tl-0-2k-0719", "tl-0-2k-0033", "tl-0-2k-0299", "tl-0-2k-0024"], "tag": "encourage"}, {"text": "Kaunti-kaunti, malaki din ang mararating.", "translation": "少しずつでも、大きなところへ行けるよ。", "words": ["tl-0-2k-0278", "tl-0-2k-0069", "tl-0-2k-0026", "tl-0-2k-0072"], "tag": "encourage"}, {"text": "Bawat salita, bagong liwanag.", "translation": "言葉ひとつごとに、新しい光だよ。", "words": ["tl-0-2k-0251", "tl-0-2k-0085", "tl-0-2k-0059", "tl-0-2k-0317"], "tag": "encourage"}, {"text": "Wala kang dapat ikatakot.", "translation": "怖がることは何もないよ。", "words": ["tl-0-2k-0022", "tl-0-2k-0100", "tl-0-2k-0237"], "tag": "encourage"}, {"text": "Tandaan mo, husay mo'y lumalaki araw-araw.", "translation": "覚えていて、あなたの力は毎日伸びているよ。", "words": ["tl-0-2k-0341", "tl-0-2k-0525", "tl-0-2k-0069", "tl-0-2k-0726"], "tag": "encourage"}, {"text": "Sigla ka lang, tuloy tayo.", "translation": "元気を出して、続けよう。", "words": ["tl-0-2k-0560", "tl-0-2k-0033", "tl-0-2k-0180", "tl-0-2k-0058"], "tag": "encourage"}, {"text": "Sa bawat pagkakamali, may tuto.", "translation": "間違いひとつごとに、学びがあるよ。", "words": ["tl-0-2k-0251", "tl-0-2k-0340", "tl-0-2k-0466"], "tag": "encourage"}, {"text": "Ikaw ang may pinakamalaking tiwala sa sarili mo.", "translation": "自分を一番信じているのはあなただよ。", "words": ["tl-0-2k-0118", "tl-0-2k-0069", "tl-0-2k-0774", "tl-0-2k-0095"], "tag": "encourage"}, {"text": "Muli, at muli, tuloy lang tayo.", "translation": "何度でも、続けていこう。", "words": ["tl-0-2k-0178", "tl-0-2k-0180", "tl-0-2k-0033", "tl-0-2k-0058"], "tag": "encourage"}, {"text": "Kaibigan mo ang bawat salitang natutunan mo.", "translation": "覚えた言葉はどれもあなたの友達だよ。", "words": ["tl-0-2k-0154", "tl-0-2k-0251", "tl-0-2k-0085", "tl-0-2k-0466"], "tag": "encourage"}, {"text": "Ingat lang, dahan-dahan pero tuloy.", "translation": "気をつけて、ゆっくりでも続けてね。", "words": ["tl-0-2k-0411", "tl-0-2k-0033", "tl-0-2k-0931", "tl-0-2k-0057", "tl-0-2k-0180"], "tag": "encourage"}, {"text": "Sino mang magsimula, may pag-asa.", "translation": "始める人には誰にでも希望があるよ。", "words": ["tl-0-2k-0134", "tl-0-2k-0067", "tl-0-2k-0208", "tl-0-2k-0587"], "tag": "encourage"}, {"text": "Sa bawat umaga, bagong pagkakataon.", "translation": "毎朝が、新しいチャンスだよ。", "words": ["tl-0-2k-0251", "tl-0-2k-0264", "tl-0-2k-0059", "tl-0-2k-0392"], "tag": "encourage"}, {"text": "Magpahinga ka muna.", "translation": "少し休んでね。", "words": ["tl-0-2k-0721", "tl-0-2k-0193"], "tag": "rest"}, {"text": "Pagod ka na, tulog muna.", "translation": "もう疲れたね、まず眠ろう。", "words": ["tl-0-2k-0605", "tl-0-2k-0228", "tl-0-2k-0193"], "tag": "rest"}, {"text": "Huwag mong pilitin ang sarili mo.", "translation": "自分に無理をさせないでね。", "words": ["tl-0-2k-0092", "tl-0-2k-0223", "tl-0-2k-0095"], "tag": "rest"}, {"text": "Tubig muna, tapos pahinga.", "translation": "まず水を、それから休憩を。", "words": ["tl-0-2k-0246", "tl-0-2k-0193", "tl-0-2k-0135", "tl-0-2k-0721"], "tag": "rest"}, {"text": "Ayos lang, magpahinga ka.", "translation": "休むのは大丈夫なことだよ。", "words": ["tl-0-2k-0254", "tl-0-2k-0033", "tl-0-2k-0721"], "tag": "rest"}, {"text": "Bukas na lang ang natitira.", "translation": "残りは明日でいいよ。", "words": ["tl-0-2k-0242", "tl-0-2k-0033", "tl-0-2k-0761"], "tag": "rest"}, {"text": "Higa ka muna, walang bilis-bilisan.", "translation": "少し横になって、急がなくていいよ。", "words": ["tl-0-2k-0849", "tl-0-2k-0193", "tl-0-2k-0022", "tl-0-2k-0328"], "tag": "rest"}, {"text": "Kaunting antok, kaunting tulog.", "translation": "少し眠いなら、少し寝てね。", "words": ["tl-0-2k-0278", "tl-0-2k-1182", "tl-0-2k-0228"], "tag": "rest"}, {"text": "Tahimik muna, mamaya na ulit.", "translation": "少し静かに、また後でね。", "words": ["tl-0-2k-0333", "tl-0-2k-0193", "tl-0-2k-0568", "tl-0-2k-0364"], "tag": "rest"}, {"text": "Kape o gatas, kahit ano, magpahinga ka.", "translation": "コーヒーでも牛乳でも、まず休んでね。", "words": ["tl-0-2k-0915", "tl-0-2k-0970", "tl-0-2k-0098", "tl-0-2k-0032", "tl-0-2k-0721"], "tag": "rest"}, {"text": "Malamig na tubig, mabuting pahinga.", "translation": "冷たい水、いい休憩に。", "words": ["tl-0-2k-0373", "tl-0-2k-0246", "tl-0-2k-0096", "tl-0-2k-0721"], "tag": "rest"}, {"text": "Hindi kailangang araw-araw, may pahinga rin.", "translation": "毎日じゃなくていい、休みもあるよ。", "words": ["tl-0-2k-0009", "tl-0-2k-0079", "tl-0-2k-0726", "tl-0-2k-0721", "tl-0-2k-0026"], "tag": "rest"}, {"text": "Payapang isip, mahalaga rin iyan.", "translation": "穏やかな心、それも大切なことだよ。", "words": ["tl-0-2k-0841", "tl-0-2k-0050", "tl-0-2k-0204", "tl-0-2k-0026", "tl-0-2k-0052"], "tag": "rest"}, {"text": "Isara mo muna ang libro, oras na ng tulog.", "translation": "本を閉じて、眠る時間だよ。", "words": ["tl-0-2k-0777", "tl-0-2k-0193", "tl-0-2k-0759", "tl-0-2k-0230", "tl-0-2k-0228"], "tag": "rest"}, {"text": "Kumusta ka ngayon?", "translation": "今日はどう？", "words": ["tl-0-2k-0520", "tl-0-2k-0040"], "tag": "any"}, {"text": "Salamat sa pagbisita mo dito.", "translation": "ここに来てくれてありがとう。", "words": ["tl-0-2k-0359", "tl-0-2k-0577", "tl-0-2k-0046"], "tag": "any"}, {"text": "Isang araw, isang salita.", "translation": "一日にひとつの言葉。", "words": ["tl-0-2k-0014", "tl-0-2k-0080", "tl-0-2k-0085"], "tag": "any"}, {"text": "Kape ba, o tubig?", "translation": "コーヒー、それとも水？", "words": ["tl-0-2k-0915", "tl-0-2k-0246"], "tag": "any"}, {"text": "Maganda ang panahon ngayon.", "translation": "今日はいい天気だね。", "words": ["tl-0-2k-0104", "tl-0-2k-0138", "tl-0-2k-0040"], "tag": "any"}, {"text": "Kaibigan mo ang mga salitang ito.", "translation": "この言葉たちは、あなたの友達だよ。", "words": ["tl-0-2k-0154", "tl-0-2k-0085", "tl-0-2k-0024"], "tag": "any"}, {"text": "Sige, simulan na natin.", "translation": "よし、始めよう。", "words": ["tl-0-2k-0268", "tl-0-2k-0208", "tl-0-2k-0076"], "tag": "any"}, {"text": "Bagong salita, bagong mundo.", "translation": "新しい言葉、新しい世界。", "words": ["tl-0-2k-0059", "tl-0-2k-0085", "tl-0-2k-0462"], "tag": "any"}, {"text": "Ingat ka palagi.", "translation": "いつも気をつけてね。", "words": ["tl-0-2k-0411", "tl-0-2k-0755"], "tag": "any"}, {"text": "Ang saya ng aral ngayon.", "translation": "今日の勉強は楽しいね。", "words": ["tl-0-2k-0367", "tl-0-2k-0146", "tl-0-2k-0040"], "tag": "any"}, {"text": "Pusa o aso, alin ang gusto mo?", "translation": "猫と犬、どっちが好き？", "words": ["tl-0-2k-1514", "tl-0-2k-0698", "tl-0-2k-0564", "tl-0-2k-0078"], "tag": "any"}, {"text": "Bulaklak sa bahay, ang ganda.", "translation": "家に花、きれいだね。", "words": ["tl-0-2k-0404", "tl-0-2k-0077", "tl-0-2k-0104"], "tag": "any"}, {"text": "Ulan man o araw, tuloy ang buhay.", "translation": "雨でも晴れでも、生活は続くよ。", "words": ["tl-0-2k-0437", "tl-0-2k-0067", "tl-0-2k-0080", "tl-0-2k-0180", "tl-0-2k-0063"], "tag": "any"}, {"text": "Bundok at dagat, saan ka gustong pumunta?", "translation": "山と海、どこに行きたい？", "words": ["tl-0-2k-0482", "tl-0-2k-0444", "tl-0-2k-0153", "tl-0-2k-0078", "tl-0-2k-0158"], "tag": "any"}, {"text": "Ang linis ng bahay mo ngayon.", "translation": "今日は家がきれいだね。", "words": ["tl-0-2k-0438", "tl-0-2k-0077", "tl-0-2k-0040"], "tag": "any"}, {"text": "Malaya at libre, ang saya niyan.", "translation": "自由で無料、それは楽しいね。", "words": ["tl-0-2k-0487", "tl-0-2k-1561", "tl-0-2k-0367", "tl-0-2k-0580"], "tag": "any"}, {"text": "Tahimik na hapon, mabuti iyan.", "translation": "静かな午後、いいものだね。", "words": ["tl-0-2k-0333", "tl-0-2k-0330", "tl-0-2k-0096", "tl-0-2k-0052"], "tag": "any"}, {"text": "Isa, dalawa, tatlo, tuloy tayo.", "translation": "1、2、3、続けよう。", "words": ["tl-0-2k-0014", "tl-0-2k-0066", "tl-0-2k-0163", "tl-0-2k-0180", "tl-0-2k-0058"], "tag": "any"}, {"text": "Kanin at itlog, simpleng pagkain.", "translation": "ご飯と卵、シンプルな食事だね。", "words": ["tl-0-2k-1070", "tl-0-2k-1051", "tl-0-2k-1102", "tl-0-2k-0309"], "tag": "any"}, {"text": "Buhay ay simple lang, salamat sa araw na ito.", "translation": "人生はシンプル、今日という日に感謝だね。", "words": ["tl-0-2k-0063", "tl-0-2k-1102", "tl-0-2k-0033", "tl-0-2k-0359", "tl-0-2k-0080", "tl-0-2k-0024"], "tag": "any"}]